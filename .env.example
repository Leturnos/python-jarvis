# Chave de API para operações de LLM (Use a chave correspondente ao active_provider definido no config.yaml)
# Para Gemini: https://aistudio.google.com/app/apikey
# Para OpenAI: https://platform.openai.com/api-keys
# Para Anthropic: https://console.anthropic.com/settings/keys
# Para DeepSeek: https://platform.deepseek.com/
# Para OpenRouter: https://openrouter.ai/keys
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Caminho para o executável do Warp Terminal
# Exemplo (Windows): C:\Users\SeuUsuario\AppData\Local\Programs\Warp\Warp.exe
WARP_PATH=

# Caminho do projeto usado pelos comandos automáticos
# Exemplo: C:\Programacao\MVP
PROJECT_PATH=